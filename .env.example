# =============================================================================
# qwen-coprocessor-stack environment
#
# Copy to .env and fill in. Secrets are never read by Claude Code directly —
# Claude Code only sees ANTHROPIC_AUTH_TOKEN (= LITELLM_MASTER_KEY) and talks
# to LiteLLM at ANTHROPIC_BASE_URL. The Anthropic key below is only used by
# LiteLLM when routing escalates to real Claude.
# =============================================================================

# --- Auth ---
# LiteLLM master key. Claude Code presents this as ANTHROPIC_AUTH_TOKEN.
LITELLM_MASTER_KEY=sk-local-CHANGE-ME

# Real Anthropic key — only used when the router escalates to claude-escalation.
# Leave blank to disable escalation entirely (router falls back to local Qwen).
ANTHROPIC_API_KEY=

# --- Backend endpoints ---
# Local workhorse on the Mac host (M4 Max llama.cpp Metal).
# host.docker.internal works on Docker Desktop for Mac/Windows.
QWEN_LOCAL_BASE_URL=http://host.docker.internal:8080/v1

# Aspirational remote workhorse (Strix Halo box). The router falls back
# gracefully if this hostname doesn't resolve.
QWEN_REMOTE_BASE_URL=http://strix-halo.local:8080/v1

# --- Routing heuristics (tunable) ---
# Approx-token threshold above which a request is escalated to Claude.
ROUTER_LARGE_PROMPT_TOKENS=8000

# Comma-separated keywords that force escalation when found in user messages.
ROUTER_HARD_KEYWORDS=@claude,prove,derive,architect,formal proof

# Approx-token threshold above which we prefer the remote (heavier) Qwen
# over the local one. Below this, local handles it.
ROUTER_REMOTE_THRESHOLD_TOKENS=2000

# --- Observability (optional, off by default) ---
LITELLM_LOG=INFO
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
