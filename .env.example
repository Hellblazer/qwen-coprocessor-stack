# =============================================================================
# qwen-coprocessor-stack environment
#
# Optional. The defaults baked into scripts/start-stack.sh and the
# qwen-agent-server work for the standard local setup; .env is only needed
# when you want to override paths, the model file, or routing knobs.
# =============================================================================

# --- llama-server lifecycle ---
# Where llama.cpp was cloned and built (see scripts/setup-mac-host.sh).
# LLAMA_DIR=$HOME/src/llama.cpp

# Model file inside ./models/. Must match what setup-mac-host.sh downloaded.
# HF_FILE=Qwen3.6-27B-UD-Q6_K_XL.gguf

# OpenAI-compat alias the model serves under (also the default backend.model
# for the qwen-agent-server).
# MODEL_ALIAS=qwen3.6-27b-instruct

# How long start-stack.sh waits for llama-server /health before giving up.
# Cold mmap of a 24 GB GGUF off USB-C SSD can take several minutes.
# LLAMA_HEALTH_WAIT_SECS=600

# --- qwen-agent-server (MCP supervisor) ---
# JSON array of Backend objects (id, url, model, tier, capacity, weight?).
# Defaults to a single local backend at http://localhost:8080/v1 if unset.
# QWEN_BACKENDS='[{"id":"local-27b","url":"http://localhost:8080/v1","model":"qwen3.6-27b-instruct","tier":"local","capacity":"fast"}]'

# Hard cap on concurrent supervised sessions. Eviction is LRU within the
# pool; terminal sessions are evicted first.
# QWEN_SUPERVISOR_MAX_SESSIONS=3

# Idle TTL (ms) before the reaper sweeps non-running sessions. Running
# sessions are skipped regardless of age — the cap is the backstop for
# runaway tasks.
# QWEN_SUPERVISOR_IDLE_TTL_MS=1800000

# Approx-token threshold above which the router classifies a prompt as
# "heavy" (preferring a remote, larger backend if one is configured).
# ROUTER_HEAVY_THRESHOLD_TOKENS=2000

# Comma-separated keywords that force "heavy" classification regardless
# of length.
# ROUTER_HEAVY_KEYWORDS=prove,derive,architect,design
