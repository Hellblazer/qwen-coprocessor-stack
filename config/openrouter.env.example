# OpenRouter credentials for the qwen-coprocessor-stack supervisor.
# REFERENCES ONLY — NO secrets in this file. Safe to commit.
#
# The values are 1Password secret references (op://…), resolved at launch:
#
#   op run --env-file=config/openrouter.env.example -- claude
#       (op injects the resolved secret into the child env, scrubs it after)
#
#   # or resolve once into the shell that launches Claude Code:
#   export OPENROUTER_API_KEY="$(op read 'op://Private/OpenRouter API/credential')"
#   claude
#
# IMPORTANT: the supervisor reads api_key_env (e.g. OPENROUTER_API_KEY) from its
# process env AT REQUEST TIME, and it is npx-spawned by Claude Code — so the key
# must be in the env that LAUNCHES Claude Code. Exporting it mid-session (e.g. in
# a one-off shell) does NOT reach the already-running supervisor; relaunch.
#
# Provisioning a runtime key (from the management/provisioning key in op):
#   PROV="$(op read 'op://Private/OpenRouter Management API Key - OpenRouter Provisioning/credential')"
#   curl -s https://openrouter.ai/api/v1/keys -H "Authorization: Bearer $PROV" \
#        -H 'Content-Type: application/json' -d '{"name":"qcs","limit":5}'   # returns key once
#   # then store the returned key:  op item create --category "API Credential" \
#   #     --title "OpenRouter API" --vault Private credential=sk-or-...

OPENROUTER_API_KEY=op://Private/OpenRouter API/credential
